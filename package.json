{
  "name": "usb-relay-workspace",
  "version": "3.0.0",
  "private": true,
  "description": "Workspace with a reusable USB relay library, Express API, and Vite React frontend.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "npm run dev --workspace @usb-relay/api",
    "dev:web": "npm run dev --workspace @usb-relay/web",
    "scan": "npm run scan --workspace @usb-relay/lib",
    "test:hardware": "npm run test --workspace @usb-relay/lib",
    "build": "npm run build --workspace @usb-relay/web"
  },
  "engines": {
    "node": ">=20"
  }
}
