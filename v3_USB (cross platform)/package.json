{
  "name": "usb-relay-nodejs",
  "version": "2.0.0",
  "description": "Node.js HID driver for dcttech USB relay board (0x16c0:0x05df)",
  "main": "src/app.js",
  "exports": {
    ".": "./src/usbrelay/index.js"
  },
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "test": "node scripts/test-relay.js",
    "scan": "node -e \"import('./src/usbrelay/index.js').then(({findDevices}) => console.log(findDevices()));\""
  },
  "dependencies": {
    "node-hid": "^3.3.0",
    "usb": "^2.17.0"
  }
}
